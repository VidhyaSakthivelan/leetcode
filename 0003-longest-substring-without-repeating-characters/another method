class Solution {
    public int lengthOfLongestSubstring(String s) {
        var m = new java.util.HashMap<Character, Integer>();
        int l = 0, mx = 0;
        for (int r = 0; r < s.length(); r++) {
            char c = s.charAt(r);
            if (m.containsKey(c) && m.get(c) >= l)
                l = m.get(c) + 1;
            m.put(c, r);
            mx = Math.max(mx, r - l + 1);
        }
        return mx;
    }
}
